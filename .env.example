# Supabase (copy values into `.env`; do not commit secrets)
SUPABASE_URL=
# Same project URL as SUPABASE_URL (Vite exposes only VITE_* to the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY is the service role key (Python Supabase client and the credentials API; keep secret)
SUPABASE_SERVICE_KEY=

# API (Fastapi `api_app.py`): Fernet key for encrypting MeroShare passwords at rest
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Comma-separated browser origins allowed to call the API (CORS). Defaults to local Vite dev URLs.
# Production: MUST include the exact SPA origin or POST /api/* and POST /refresh fail in the browser.
# Example: https://your-app.vercel.app,https://your-app.netlify.app
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Production frontend build (Vite; set on your static host CI / dashboard) ---
# Required when the API is hosted separately (e.g. Render Docker). No trailing slash.
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional (Docker/Linux): Chromium binary and driver paths. The Dockerfile sets these; omit locally on macOS/Windows with Google Chrome.
# CHROME_BIN=/usr/bin/chromium
# CHROMEDRIVER_PATH=/usr/bin/chromedriver
