# Supabase (copy values into `.env`; do not commit secrets)
SUPABASE_URL=
# Same project URL as SUPABASE_URL (Vite exposes only VITE_* to the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY is the service role key (Python Supabase client and the credentials API; keep secret)
SUPABASE_SERVICE_KEY=

# API (Fastapi `api_app.py`): Fernet key for encrypting MeroShare passwords at rest
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Comma-separated browser origins allowed to call the API (CORS). Defaults to local Vite dev URLs.
# Production example: https://your-app.vercel.app,https://your-app.netlify.app
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: FastAPI origin for the React app when the API is not same-origin (production).
# VITE_API_BASE_URL=
