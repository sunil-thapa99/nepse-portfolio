# Copy to .env.production locally, or set these in your static host’s build environment.
# Vite inlines VITE_* at build time.
#
# Supabase → Authentication → URL Configuration:
# - Site URL: production SPA origin (e.g. https://your-app.vercel.app).
# - Redirect URLs: include that origin plus any staging/preview hosts and local dev URLs
#   (http://localhost:5173, etc.). Sign-up uses the browser origin as emailRedirectTo.

# Public Supabase (same as local .env)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# FastAPI origin where POST /refresh and POST /api/meroshare/credentials are served.
# No trailing slash. Example Render API:
# VITE_API_BASE_URL=https://nepse-portfolio-1xc6.onrender.com
